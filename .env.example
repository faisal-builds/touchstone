# Copy to .env for local development. NEVER commit a real .env.
TOUCHSTONE_ENVIRONMENT=local
TOUCHSTONE_DATABASE_URL=postgresql+asyncpg://touchstone:touchstone@localhost:5432/touchstone
TOUCHSTONE_REDIS_URL=redis://localhost:6379/0
TOUCHSTONE_REDPANDA_BROKERS=localhost:19092
# Generate a strong secret for non-local envs: python -c "import secrets;print(secrets.token_urlsafe(48))"
TOUCHSTONE_JWT_SECRET=local-dev-secret-change-me
TOUCHSTONE_LOG_LEVEL=INFO
