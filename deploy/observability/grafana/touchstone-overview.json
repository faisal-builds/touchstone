{
  "title": "Touchstone — Platform Overview",
  "uid": "touchstone-overview",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "tags": ["touchstone"],
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "browser",
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Request rate (req/s) by service",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (job) (rate(touchstone_http_requests_total[5m]))",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "5xx error ratio by service",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1 }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (job) (rate(touchstone_http_requests_total{status=~\"5..\"}[5m])) / clamp_min(sum by (job) (rate(touchstone_http_requests_total[5m])), 0.001)",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "p95 request latency by service",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, job) (rate(touchstone_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Resident memory by pod",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (job) (process_resident_memory_bytes)",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "CPU seconds/s by service",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum by (job) (rate(process_cpu_seconds_total[5m]))",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Requests by status class",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "sum by (status) (rate(touchstone_http_requests_total[5m]))",
          "legendFormat": "{{status}}"
        }
      ]
    }
  ]
}
